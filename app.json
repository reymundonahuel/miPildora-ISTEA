{
  "expo": {
    "name": "MiPildora",
    "slug": "MiPildora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mipildora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nahuelreymundo.MiPildora"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceso a la galería para seleccionar fotos de medicamentos.",
          "cameraPermission": "La app necesita acceso a la cámara para tomar fotos de medicamentos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La app necesita acceso a tu ubicación para guardar la ubicación de la farmacia."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "La app necesita acceso a tus contactos para asociar un médico o familiar."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "La app necesita acceso al calendario para crear recordatorios de medicación."
        }
      ]
    ],
    "updates": {
      "checkAutomatically": "ON_ERROR_RECOVERY"
    },
    "experiments": {
      "reactCompiler": true
    }
  }
}
